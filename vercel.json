{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && PUPPETEER_SKIP_DOWNLOAD=true npm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 3008
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
