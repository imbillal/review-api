PORT=4000
DATABASE_URL=""

# CORS — comma-separated list of allowed web origins
WEB_ORIGIN="http://localhost:3000"

# URL of the web app (used to build invite links)
APP_URL="http://localhost:3000"

# Must match NEXTAUTH_SECRET in review-Web (used to verify session tokens)
NEXTAUTH_SECRET=""

# SMTP (invite + notification emails)
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Pinion <you@example.com>"

# S3 storage (PDF + website thumbnail uploads)
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""           # optional: for MinIO / LocalStack / S3-compatible storage
# S3_PUBLIC_URL_BASE=""    # optional: CDN base, e.g. https://cdn.example.com
